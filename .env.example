# Mall för miljövariabler. Kopiera till .env och fyll i värden.
# Filen .env läggs i .gitignore och committas ALDRIG.

# --- AI-leverantörer (modellagnostiskt lager, B-009) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Databricks Lakebase (B-018, ersätter Supabase/B-014) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# --- Databasanslutning för SQLAlchemy ---
# Lakebase är Postgres-kompatibel. Format:
# postgresql://<role>:<password>@<lakebase-host>.databricks.com/databricks_postgres?sslmode=require
DATABASE_URL=
